{
  "expo": {
    "name": "Shiv Lal Manpower",
    "slug": "shivlal-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#0F1E3D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "in.shivlal.manpower",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Required for GPS attendance check-in.",
        "NSCameraUsageDescription": "Required for selfie attendance verification."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F1E3D"
      },
      "package": "in.shivlal.manpower",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-camera",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Required for GPS attendance check-in."
        }
      ]
    ]
  }
}
