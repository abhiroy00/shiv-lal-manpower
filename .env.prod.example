# ─────────────────────────────────────────────────────────────────────────────
#  Shiv Lal Manpower Portal — Production Environment Variables
#
#  Copy this file to .env.prod on your EC2 server and fill in every value.
#  NEVER commit .env.prod to version control.
#
#  Location on server: /opt/shivlal-manpower/.env.prod
# ─────────────────────────────────────────────────────────────────────────────

# ── Django Core ───────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.prod

# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=CHANGE-ME-to-a-long-random-string-at-least-50-characters

DEBUG=False

# Comma-separated: your EC2 Elastic IP and/or custom domain (no spaces)
# Example: ALLOWED_HOSTS=13.235.100.50,api.shivlalmanpower.com
ALLOWED_HOSTS=YOUR_EC2_ELASTIC_IP,YOUR_DOMAIN_IF_ANY

# ── PostgreSQL (used by both the db container and Django) ────────────────────
POSTGRES_USER=shivlal
POSTGRES_PASSWORD=CHANGE-ME-strong-db-password
POSTGRES_DB=shivlal_db

# Django connects to the db container by its Docker service name "db"
DB_NAME=shivlal_db
DB_USER=shivlal
DB_PASSWORD=CHANGE-ME-strong-db-password
DB_HOST=db
DB_PORT=5432

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── CORS (frontend origin — must match where the React app is served) ─────────
# Use your EC2 IP for initial deployment; add custom domain later
# Example: CORS_ALLOWED_ORIGINS=http://13.235.100.50,https://shivlalmanpower.com
CORS_ALLOWED_ORIGINS=http://YOUR_EC2_ELASTIC_IP

# ── AWS S3 (optional — for media file storage; remove if using local volume) ──
# AWS_STORAGE_BUCKET_NAME=shivlal-manpower-media
# AWS_S3_REGION_NAME=ap-south-1
# AWS_ACCESS_KEY_ID=YOUR_IAM_ACCESS_KEY
# AWS_SECRET_ACCESS_KEY=YOUR_IAM_SECRET_KEY

# ── Sentry (optional — error tracking) ───────────────────────────────────────
# SENTRY_DSN=https://key@sentry.io/project-id
